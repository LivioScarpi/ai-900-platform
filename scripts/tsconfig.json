{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "downlevelIteration": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "../.scripts-out",
    "rootDir": ".",
    "types": ["node"],
    "ignoreDeprecations": "5.0"
  },
  "include": ["./**/*.ts"]
}
